#!/bin/bash
# .githooks/pre-push

input=$(cat)
remote_ref=$(echo "$input" | awk '{print $3}' | head -1)

if [[ "$remote_ref" =~ refs/heads/release/.+ ]]; then
    release_branch=${remote_ref#refs/heads/}
    
    echo ""
    echo "🔍 检测到推送 $release_branch，正在检查与 develop 的差异..."
    
    git fetch origin develop --quiet
    git fetch origin "$release_branch" --quiet 2>/dev/null
    
    diff_commits=$(git log origin/develop.."$release_branch" --oneline 2>/dev/null)
    
    if [ -z "$diff_commits" ]; then
        echo "✅ $release_branch 与 origin/develop 没有差异"
        echo "📤 直接推送 $release_branch..."
        exit 0  # 没差异，让 Git 正常推送
    fi
    
    # ========== 有差异，手动处理 ==========
    echo ""
    echo "⚠️  发现 $release_branch 有以下提交未同步到 develop："
    echo "----------------------------------------"
    echo "$diff_commits"
    echo "----------------------------------------"
    echo ""
    
    exec < /dev/tty
    read -p "是否同步到 develop 并推送？(y/n) " confirm
    
    if [[ "$confirm" != "y" ]]; then
        echo "❌ 已取消"
        exit 1
    fi
    
    # 检查工作区
    if ! git diff-index --quiet HEAD --; then
        echo "❌ 有未提交的更改"
        exit 1
    fi
    
    echo "🚀 开始同步..."
    
    git checkout develop || { echo "❌ 切换失败"; exit 1; }
    git rebase origin/develop || { echo "❌ rebase 冲突"; exit 1; }
    git rebase "$release_branch" || { echo "❌ rebase 冲突"; exit 1; }
    
    echo "📤 推送 develop..."
    git push origin develop || { echo "❌ 推送失败"; exit 1; }
    
    echo "📤 推送 $release_branch..."
    git checkout "$release_branch"
    git push origin "$release_branch" || { echo "❌ 推送失败"; exit 1; }
    
    echo ""
    echo "✅ ============================================"
    echo "✅ 同步完成！develop 和 $release_branch 已推送"
    echo "✅ ============================================"
    
    # 关键：返回 1 阻止 Git 再次推送（我们已经手动推过了）
    exit 1
fi

exit 0
