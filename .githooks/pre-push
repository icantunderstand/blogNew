#!/bin/bash
# .githooks/pre-push

input=$(cat)
remote_ref=$(echo "$input" | awk '{print $3}' | head -1)

if [[ "$remote_ref" =~ refs/heads/release/.+ ]]; then
    release_branch=${remote_ref#refs/heads/}
    
    echo ""
    echo "🔍 检测到推送 $release_branch，正在检查与 develop 的差异..."
    
    git fetch origin develop --quiet
    git fetch origin "$release_branch" --quiet 2>/dev/null
    
    # 只检查 release 是否领先 develop
    release_ahead=$(git log origin/develop.."$release_branch" --oneline 2>/dev/null)
    
    if [ -z "$release_ahead" ]; then
        echo "✅ $release_branch 没有新提交需要同步到 develop"
        echo "📤 直接推送 $release_branch..."
        exit 0
    fi
    
    # ========== 有差异，显示详情 ==========
    echo ""
    echo "⚠️  $release_branch 有以下提交未同步到 develop："
    echo "----------------------------------------"
    echo "$release_ahead"
    echo "----------------------------------------"
    echo ""
    
    exec < /dev/tty
    read -p "是否同步到 develop 并推送？(y/n) " confirm
    
    if [[ "$confirm" != "y" ]]; then
        echo "❌ 已取消"
        exit 1
    fi
    
    # 检查工作区
    if ! git diff-index --quiet HEAD --; then
        echo "❌ 有未提交的更改"
        exit 1
    fi
    
    echo ""
    echo "🚀 开始同步 $release_branch → develop..."
    
    # 更新 develop（合并 release 的新提交）
    git checkout develop || { echo "❌ 切换失败"; exit 1; }
    git rebase origin/develop || { echo "❌ rebase origin/develop 冲突"; exit 1; }
    git rebase "$release_branch" || { echo "❌ rebase $release_branch 冲突"; exit 1; }
    
    # 推送两个分支
    echo ""
    echo "📤 推送 develop..."
    git push origin develop || { echo "❌ 推送 develop 失败"; exit 1; }
    
    echo ""
    echo "📤 推送 $release_branch..."
    git checkout "$release_branch" || { echo "❌ 切换失败"; exit 1; }
    git push origin "$release_branch" || { echo "❌ 推送 $release_branch 失败"; exit 1; }
    
    echo ""
    echo "✅ ============================================"
    echo "✅ 同步完成！release → develop 已更新"
    echo "✅ ============================================"
    # 强制终止，不让 Git 继续
    kill -9 $PPID 2>/dev/null
    exit 1
fi

exit 0
